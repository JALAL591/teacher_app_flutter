<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
>
<LinearLayout
    android:id="@+id/connectedStudentRoot"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="?attr/colorSurfaceVariant">

    <!-- Avatar دائري 54dp + نقطة خضراء -->
    <FrameLayout
        android:layout_width="54dp"
        android:layout_height="54dp">

        <FrameLayout
            android:id="@+id/studentAvatar"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/student_avatar_1">

            <TextView
                android:id="@+id/studentEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="&#x1F464;"
                android:textSize="20sp"
                android:textColor="?attr/colorSurface"
                android:contentDescription="@string/desc_student_avatar" />

        </FrameLayout>

        <!-- نقطة خضراء (متصل) -->
        <View
            android:id="@+id/onlineIndicator"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/online_indicator_bg" />

    </FrameLayout>

    <!-- معلومات الطالب -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/studentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_student"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorSurface"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/onlineStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_connected_now"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- وقت الاتصال يسار -->
    <TextView
        android:id="@+id/connectionTimeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant" />

</LinearLayout>

</layout>