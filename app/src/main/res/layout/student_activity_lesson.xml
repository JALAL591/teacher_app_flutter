<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/main_background"
        android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/main_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/rounded_chip"
            android:src="@drawable/ic_arrow_right"
            app:tint="@color/icon_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lessonTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/subjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/pointsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_orange"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:textColor="@color/amber_500"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Tab Switcher -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="@color/input_background"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/contentTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/rounded_purple_selector"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/student_content_tab"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/homeworkTab"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/student_homework_tab"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Content ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Content Tab -->
            <LinearLayout
                android:id="@+id/contentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Video Player Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/videoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <VideoView
                            android:id="@+id/videoView"
                            android:layout_width="match_parent"
                            android:layout_height="220dp" />

                        <!-- Video Thumbnail for broadcast lessons -->
                        <ImageView
                            android:id="@+id/videoThumbnail"
                            android:layout_width="match_parent"
                            android:layout_height="220dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <ImageButton
                            android:id="@+id/playButton"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:background="@drawable/rounded_purple_selector"
                            android:src="@drawable/ic_play"
                            android:visibility="gone"
                            app:tint="@android:color/white" />

                        <!-- Play Button for video thumbnail -->
                        <ImageButton
                            android:id="@+id/playVideoButton"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:layout_gravity="center"
                            android:background="@drawable/rounded_purple_selector"
                            android:src="@drawable/ic_play"
                            android:visibility="gone"
                            app:tint="@android:color/white" />

                        <ProgressBar
                            android:id="@+id/videoProgress"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:visibility="gone" />
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <!-- Lesson Image Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/lessonImageCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp">

                    <ImageView
                        android:id="@+id/lessonImage"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Images Card (for broadcast lessons) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/imagesCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الصور"
                            android:textColor="@color/indigo_400"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/imagesRecycler"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:visibility="gone" />

                        <Button
                            android:id="@+id/openVideoButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:backgroundTint="@color/indigo_600"
                            android:text="تشغيل الفيديو"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PDF Viewer Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/pdfCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_pdf"
                                app:tint="@color/error" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:text="ملف PDF"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />

                            <Button
                                android:id="@+id/openPdfButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:backgroundTint="@color/indigo_600"
                                android:text="فتح"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                app:cornerRadius="8dp" />
                        </LinearLayout>

                        <FrameLayout
                            android:id="@+id/pdfViewContainer"
                            android:layout_width="match_parent"
                            android:layout_height="500dp"
                            android:layout_marginTop="12dp"
                            android:visibility="gone" />

                        <!-- PDF Page Navigation -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:padding="8dp"
                            android:visibility="gone">

                            <ImageButton
                                android:id="@+id/pdfPrevPage"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_arrow_right"
                                app:tint="@color/indigo_400" />

                            <TextView
                                android:id="@+id/pdfPageIndicator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="16dp"
                                android:text="1/1"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp" />

                            <ImageButton
                                android:id="@+id/pdfNextPage"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@drawable/ic_arrow_left"
                                app:tint="@color/indigo_400" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/extractTextButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:backgroundTint="@color/indigo_600"
                            android:text="استخراج النص"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/student_lesson_content"
                                android:textColor="@color/indigo_400"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/readAloudButton"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/rounded_indigo"
                                android:src="@drawable/ic_volume"
                                app:tint="@color/indigo_400" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/lessonContent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:lineSpacingExtra="8dp"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/readButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/primary"
                    android:text="@string/student_read_complete"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <!-- Homework Tab -->
            <LinearLayout
                android:id="@+id/homeworkLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/questionsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <ImageView
                    android:id="@+id/homeworkPreview"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/captureHomeworkButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/input_background"
                    android:text="@string/student_capture_homework"
                    android:textColor="@color/text_primary"
                    app:cornerRadius="16dp" />

                <Button
                    android:id="@+id/submitHomeworkButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/emerald_500"
                    android:text="@string/student_submit_homework"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveHomeworkButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/amber_500"
                    android:text="حفظ الواجب"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    app:cornerRadius="16dp" />
            </LinearLayout>
        </FrameLayout>
    </ScrollView>

    <!-- Floating Assistant Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAssistant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_bot"
        app:backgroundTint="@color/primary"
        app:tint="@android:color/white" />
</LinearLayout>
</layout>
