<?xml version="1.0" encoding="utf-8"?>
<!-- Modern Floating Navigation Bar - 2026 Glassmorphism -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Frosted glass effect (semi-transparent white) -->
    <solid android:color="#B3FFFFFF" />

    <!-- Extra rounded pill shape (32dp) -->
    <corners android:radius="32dp" />

    <!-- Subtle white border for glass effect -->
    <stroke
        android:width="1.5dp"
        android:color="#E6FFFFFF" />

</shape>
