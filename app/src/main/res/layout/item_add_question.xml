<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
>
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="?attr/colorSurfaceVariant">

    <Spinner
        android:id="@+id/questionTypeSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_spinner_modern"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/qTextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="نص السؤال"
        android:padding="12dp"
        android:background="@drawable/bg_spinner_modern"
        android:textColor="?attr/colorOnSurface"
        android:textColorHint="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/mcqOptionsArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/opt1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="خيار 1"
            android:padding="12dp"
            android:background="@drawable/bg_spinner_modern"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/opt2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="خيار 2"
            android:padding="12dp"
            android:background="@drawable/bg_spinner_modern"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/correctOptSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_spinner_modern" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tfArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <RadioGroup
            android:id="@+id/tfGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioTrue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="صح"
                android:textColor="?attr/colorOnSurface" />

            <RadioButton
                android:id="@+id/radioFalse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="خطأ"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginStart="16dp" />
        </RadioGroup>
    </LinearLayout>

    <ImageView
        android:id="@+id/removeQuestionBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_delete"
        android:layout_gravity="end"
        android:padding="8dp"
        android:contentDescription="@string/btn_delete" />

</LinearLayout>

</layout>