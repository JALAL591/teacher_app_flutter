<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
>
<!-- Modern 2026 Class Manager Activity -->
<androidx.coordinatorlayout.widget.CoordinatorLayout


    android:id="@+id/classManagerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Modern App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_icon_button_light"
                android:src="@drawable/ic_arrow_back"
                android:padding="12dp"
                android:contentDescription="@string/btn_back"
                app:tint="?attr/colorOnSurface" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginHorizontal="16dp">

                <TextView
                    android:id="@+id/subjectTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_subject"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/gradeSectionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mock_grade"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="1" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/addLessonButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:minWidth="56dp"
                android:minHeight="56dp"
                android:background="@drawable/bg_fab_modern"
                android:src="@drawable/ic_add_lesson"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:elevation="8dp"
                android:translationZ="4dp"
                android:contentDescription="@string/btn_add_lesson"
                app:tint="?attr/colorOnSurface" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Edit Lessons Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/editLessonsButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/title_edit_lesson"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimary"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/btn_capsule_primary"
                android:stateListAnimator="@null"
                app:icon="@drawable/ic_add_lesson"
                app:iconTint="?attr/colorOnSurface"
                app:iconSize="20dp"
                app:iconGravity="textStart" />

            <!-- Drafts Section -->
            <TextView
                android:id="@+id/draftsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_drafts"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/localDraftsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_local_lesson" />

            <!-- Published Section -->
            <TextView
                android:id="@+id/publishedTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_published"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/publishedLessonsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_published_lesson" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>