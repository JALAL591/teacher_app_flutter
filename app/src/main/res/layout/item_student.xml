<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- صورة الطالب -->
            <LinearLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/student_avatar_bg"
                android:gravity="center">

                <TextView
                    android:id="@+id/studentInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أ"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/studentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أحمد محمد"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/studentPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="85 نقطة"
                        android:textSize="11sp"
                        android:textColor="#F59E0B"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- أزرار الحضور والغياب -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/presentButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="✓"
                    android:textSize="20sp"
                    android:backgroundTint="#10B981"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/absentButton"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="✗"
                    android:textSize="20sp"
                    android:backgroundTint="#EF4444" />

            </LinearLayout>

        </LinearLayout>

        <!-- سجل الحضور -->
        <LinearLayout
            android:id="@+id/attendanceContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:paddingTop="16dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>