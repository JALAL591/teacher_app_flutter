<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/lessonDetailsRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/lessonDetailsScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:paddingBottom="100dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <FrameLayout
                    android:id="@+id/headerLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorPrimaryContainer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageButton
                        android:id="@+id/backButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="top|start"
                        android:layout_margin="12dp"
                        android:background="@drawable/bg_icon_button_light"
                        android:padding="12dp"
                        android:src="@drawable/ic_arrow_back"
                        app:tint="?attr/colorOnPrimaryContainer" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:layout_margin="12dp"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/broadcastButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_button_light"
                            android:src="@drawable/ic_broadcast"
                            app:tint="?attr/colorOnPrimaryContainer" />

                        <ImageButton
                            android:id="@+id/editButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_icon_button_light"
                            android:src="@drawable/ic_edit"
                            app:tint="?attr/colorOnPrimaryContainer" />

                        <ImageButton
                            android:id="@+id/deleteButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_icon_button_light"
                            android:src="@drawable/ic_delete"
                            app:tint="@color/error" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/lessonEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="40dp"
                        android:text="📖"
                        android:textSize="48sp" />

                    <TextView
                        android:id="@+id/lessonTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="24dp"
                        android:gravity="center"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/metaCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="-12dp"
                    app:cardCornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/headerLayout">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView android:id="@+id/lessonUnit" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView android:id="@+id/publishStatusText" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/contentSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/metaCard">
                    
                    <TextView android:id="@+id/emptyContentText" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" />
                    <TextView android:id="@+id/lessonContent" android:layout_width="match_parent" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/attachmentsSection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/contentSection">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/pdfCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                            <com.github.barteksc.pdfviewer.PDFView
                                android:id="@+id/pdfView"
                                android:layout_width="match_parent"
                                android:layout_height="400dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center">
                                <ImageButton android:id="@+id/pdfPrevPage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_arrow_back"/>
                                <TextView android:id="@+id/pdfPageIndicator" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1/1" />
                                <ImageButton android:id="@+id/pdfNextPage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:src="@drawable/ic_arrow_forward"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/videoCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="200dp">
                            <ImageView android:id="@+id/videoThumbnail" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" />
                            <ImageButton android:id="@+id/playVideoButton" android:layout_width="64dp" android:layout_height="64dp" android:layout_gravity="center" android:src="@drawable/ic_play" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/imagesCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp">
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/imagesRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <com.edu.teacher.BottomNav
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>
