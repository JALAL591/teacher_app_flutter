<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/icon_button_bg"
            android:text="→" />

        <TextView
            android:id="@+id/pageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="تجهيز فصل جديد"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:gravity="center" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- أيقونة -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/icon_gradient_bg"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="➕"
                    android:textSize="36sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إضافة مادة دراسية جديدة"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#64748B"
                android:layout_marginBottom="24dp" />

            <!-- بطاقة النموذج -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:background="#FFFFFF">

                    <!-- اسم المادة -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="اسم المادة"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/subjectInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="مثال: رياضيات، علوم، لغة عربية..." />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- المرحلة الدراسية -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="المرحلة الدراسية"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#64748B"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/gradeSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/spinner_bg"
                        android:layout_marginBottom="20dp" />

                    <!-- الشعبة -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الشعبة / الفصل"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#64748B"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/sectionsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="24dp" />

                    <!-- زر الحفظ -->
                    <Button
                        android:id="@+id/saveButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="✅ تأكيد وإنشاء الفصل"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:backgroundTint="#4F46E5" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- تذييل توضيحي -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#EEF2FF"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="بمجرد إنشاء الفصل، سيظهر في قائمة الفصول المتاحة لك عند إضافة أي درس جديد."
                    android:textSize="11sp"
                    android:textColor="#4F46E5"
                    android:layout_marginStart="12dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>