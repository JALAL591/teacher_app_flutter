<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphism background for cards (Dark/Blue tint) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Semi-transparent blue/dark background -->
    <solid android:color="@color/glass_bg_dark" />
    
    <!-- Rounded corners -->
    <corners android:radius="@dimen/radius_md" />
    
    <!-- Thin white transparent stroke for glass edge -->
    <stroke
        android:width="1dp"
        android:color="@color/glass_border_dark" />
</shape>
