# Auto detect text files and perform LF normalization
* text=auto

# Force LF for shell scripts and Gradle wrapper
gradlew text eol=lf
*.sh text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.keystore binary
*.jks binary
*.apk binary
*.aab binary
