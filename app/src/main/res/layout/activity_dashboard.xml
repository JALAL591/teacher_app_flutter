<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
>
<!-- Modern 2026 Bento Grid Dashboard -->
<androidx.coordinatorlayout.widget.CoordinatorLayout


    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Modern App Bar with Blur -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="scroll|enterAlways">

            <!-- Modern Header -->
            <LinearLayout
                android:id="@+id/toolbarLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="16dp">

                <!-- Profile Avatar -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_gradient" />
                    <ImageView
                        android:id="@+id/avatarImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_avatar" />
                </FrameLayout>

                <!-- Title & Subtitle -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:id="@+id/teacherNameText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/dashboardSubtitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_subtitle"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:maxLines="1" />

                </LinearLayout>

                <!-- Theme Toggle Button -->
                <ImageButton
                    android:id="@+id/themeToggleButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_icon_button_white"
                    android:src="@drawable/ic_theme"
                    android:padding="12dp"
                    android:contentDescription="@string/settings_label_night_mode"
                    app:tint="?attr/colorOnSurface" />

                <!-- Settings Button -->
                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_icon_button_white"
                    android:src="@drawable/ic_settings"
                    android:padding="12dp"
                    android:contentDescription="@string/nav_settings"
                    app:tint="?attr/colorOnSurface" />

                <!-- Logout Button -->
                <ImageButton
                    android:id="@+id/logoutButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_icon_button_white"
                    android:src="@drawable/ic_logout"
                    android:padding="12dp"
                    android:contentDescription="@string/dialog_logout"
                    app:tint="?attr/colorOnSurface" />

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- ===== Hero Card - Modern Bento Style ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/idCardLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_bento_card_modern"
                    android:padding="20dp">

                    <!-- Greeting -->
                    <TextView
                        android:id="@+id/greetingText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مرحباً بك"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnPrimary"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Teacher Code Label -->
                    <TextView
                        android:id="@+id/idLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_teacher_code"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnPrimary"
                        android:alpha="0.8"
                        android:layout_marginTop="8dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/greetingText" />

                    <!-- Teacher ID -->
                    <TextView
                        android:id="@+id/teacherIdText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_id"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:layout_marginTop="4dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/idLabel" />

                    <!-- Copy Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:backgroundTint="?attr/colorSurfaceVariant"
                        app:icon="@drawable/ic_copy"
                        app:iconTint="?attr/colorOnSurface"
                        app:iconSize="20dp"
                        app:cornerRadius="14dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <!-- Decorative Circles -->
                    <View
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_decorative_circle"
                        android:alpha="0.3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Bento Grid Stats Section ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نظرة عامة"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Stats Bento Grid -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/statsCardContainer"
                android:layout_width="match_parent"
                android:layout_height="140dp">

                <!-- Students Card - Large (Left) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statStudentsCard"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/statClassesCard"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bento_stats_blue"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/studentsIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_students"
                            app:tint="?attr/colorOnSurface"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/statsStudentsNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimary"
                            android:fontFamily="sans-serif-medium"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/statsStudentsLabel" />

                        <TextView
                            android:id="@+id/statsStudentsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_students"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnPrimary"
                            android:alpha="0.8"
                            android:layout_marginBottom="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Classes Card (Center) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statClassesCard"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintStart_toEndOf="@id/statStudentsCard"
                    app:layout_constraintEnd_toStartOf="@id/statPointsCard"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bento_stats_purple"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_class"
                            app:tint="?attr/colorOnSurface"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/statsClassesNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimary"
                            android:fontFamily="sans-serif-medium"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/statsClassesLabel" />

                        <TextView
                            android:id="@+id/statsClassesLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_classes"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Points Card (Right) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/statPointsCard"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    app:layout_constraintStart_toEndOf="@id/statClassesCard"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_bento_stats_green"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_points"
                            app:tint="?attr/colorOnSurface"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/statsPointsNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimary"
                            android:fontFamily="sans-serif-medium"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toTopOf="@id/statsPointsLabel" />

                        <TextView
                            android:id="@+id/statsPointsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/stat_points"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:layout_marginBottom="2dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ===== Modern Action Buttons ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إجراءات سريعة"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Action Buttons Row - Equal Size Cards -->
            <LinearLayout
                android:id="@+id/actionButtonsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Hotspot Button - Equal Size -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/hotspotButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/btn_hotspot_full"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/btn_capsule_primary"
                        android:stateListAnimator="@null"
                        app:icon="@drawable/ic_wifi"
                        app:iconTint="?attr/colorOnSurface"
                        app:iconSize="18dp"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                </com.google.android.material.card.MaterialCardView>

                <!-- Add Class Button - Equal Size -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addClassButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/title_add_class_new"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimary"
                        android:fontFamily="sans-serif-medium"
                        android:background="@drawable/btn_capsule_success"
                        android:stateListAnimator="@null"
                        app:icon="@drawable/ic_add_class"
                        app:iconTint="?attr/colorOnSurface"
                        app:iconSize="18dp"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ===== Classes Section ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/classesSectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/section_classes_full"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/viewAllButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عرض الكل"
                    android:textSize="13sp"
                    android:textColor="?attr/colorPrimary"
                    app:icon="@drawable/ic_arrow_right"
                    app:iconSize="16dp"
                    app:iconTint="?attr/colorPrimary"
                    app:iconGravity="end" />

            </LinearLayout>

            <!-- Classes RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/classesRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_class" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Modern Bottom Navigation -->
    <com.edu.teacher.BottomNav
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>