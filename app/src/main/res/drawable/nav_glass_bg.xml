<?xml version="1.0" encoding="utf-8"?>
<!-- Solid background for floating navigation bar -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Solid slate-50 color for modern clean look -->
    <solid android:color="@color/nav_glass_bg" />

    <!-- Fully rounded pill shape -->
    <corners android:radius="@dimen/nav_floating_corner_radius" />

    <!-- Subtle stroke for edge definition -->
    <stroke
        android:width="1dp"
        android:color="@color/nav_glass_border" />
</shape>
