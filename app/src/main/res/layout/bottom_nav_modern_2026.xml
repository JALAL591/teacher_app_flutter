<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:tools="http://schemas.android.com/tools" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
<!-- Modern 2026 Floating Bottom Navigation - Glassmorphism -->
<FrameLayout
    android:id="@+id/telegramNavRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <!-- Main Navigation Container with Glass Effect -->
    <LinearLayout
        android:id="@+id/navContainer"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="8dp">

        <!-- Tab 1: Home -->
        <LinearLayout
            android:id="@+id/tab1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/tabIcon1"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_home" />

            <TextView
                android:id="@+id/tabLabel1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="@string/nav_home" />

        </LinearLayout>

        <!-- Tab 2: Stats -->
        <LinearLayout
            android:id="@+id/tab2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/tabIcon2"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_stats" />

            <TextView
                android:id="@+id/tabLabel2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="@string/nav_stats" />

        </LinearLayout>

        <!-- Tab 3: Add (Center Elevated) -->
        <FrameLayout
            android:id="@+id/tab3Container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="4dp">

            <!-- Elevated center button -->
            <View
                android:id="@+id/tab3Bg"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_fab_modern"
                android:elevation="6dp" />

            <LinearLayout
                android:id="@+id/tab3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_tab_item_selector"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="12dp">

                <ImageView
                    android:id="@+id/tabIcon3"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_nav_add"
                    app:tint="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tabLabel3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:text="@string/nav_add_lesson"
                    android:visibility="gone" />

            </LinearLayout>

        </FrameLayout>

        <!-- Tab 4: Attendance -->
        <LinearLayout
            android:id="@+id/tab4"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/tabIcon4"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_attendance" />

            <TextView
                android:id="@+id/tabLabel4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="@string/nav_attendance" />

        </LinearLayout>

        <!-- Tab 5: Settings -->
        <LinearLayout
            android:id="@+id/tab5"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_tab_item_selector"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/tabIcon5"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_nav_settings" />

            <TextView
                android:id="@+id/tabLabel5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:text="@string/nav_settings" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>

</layout>